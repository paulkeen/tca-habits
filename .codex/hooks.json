{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/guard_streak.py",
            "statusMessage": "Checking streak-logic guardrail",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make -s check",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
